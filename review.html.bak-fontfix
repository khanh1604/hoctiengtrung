          const res = await fetch(`data/hanyu3-lesson-${lessonNum}.json?v=${Date.now()}`);
          if (!res.ok) throw new Error("KhÃ´ng táº£i Ä‘Æ°á»£c dá»¯ liá»‡u GiÃ¡o trÃ¬nh HÃ¡n ngá»¯ quyá»ƒn 3");
          return res.json();
        }

        const res = await fetch(`data/speaking-lesson-${lessonNum}.json?v=${Date.now()}`);
        if (res.ok) return res.json();

        throw new Error("KhÃ´ng táº£i Ä‘Æ°á»£c dá»¯ liá»‡u mÃ´n nÃ³i");
      }

